{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nofari",
  "version": "0.1.0",
  "identifier": "com.amit.nofari",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Nofari",
        "url": "index.html",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "resizable": true,
        "center": true
      },
      {
        "label": "companion",
        "title": "Nofari Companion",
        "url": "companion.html",
        "width": 96,
        "height": 96,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "resizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
