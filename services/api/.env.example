# Irma API — environment configuration. Copy to `.env` and fill secrets.
#
# Required for Phase 3 (LeadAgent synthesis):
ANTHROPIC_API_KEY=
# Model ID — verify the latest at https://docs.claude.com.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required for Phase 2 (TimeAgent / Google Calendar). All three must be set
# for calendar signals to appear; missing creds degrade gracefully with an
# AgentState.alert "calendar not linked" notice.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Comma-separated absolute paths to local git repos the CodebaseAgent watches.
# Missing / non-git paths are skipped with a warning.
IRMA_REPOS=

# Background re-observation interval (APScheduler).
IRMA_REFRESH_MINUTES=30

# Manual tunable for the companion sprite's vertical offset from the work-area
# bottom edge; consumed by the Tauri side, mirrored here for visibility.
IRMA_DOCK_CLEARANCE=80

# SQLite path (relative paths resolve from the services/api/ cwd).
IRMA_DB_PATH=./irma.db

# Bind address for the uvicorn server.
IRMA_API_HOST=127.0.0.1
IRMA_API_PORT=8765
