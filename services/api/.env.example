# Irma API — environment configuration. Copy to `.env` and fill secrets.
#
# LLM backend powering LeadAgent + /chat. One of: "anthropic" | "ollama".
# "ollama" runs fully offline against a local model — see OLLAMA_* below.
IRMA_LLM_BACKEND=anthropic

# Required when IRMA_LLM_BACKEND=anthropic.
ANTHROPIC_API_KEY=
# Model ID — verify the latest at https://docs.claude.com.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required when IRMA_LLM_BACKEND=ollama. The model must already be pulled
# (`ollama pull qwen2.5:7b`).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# Google Calendar (read-only) — TimeAgent observer.
# Fill CLIENT_ID and CLIENT_SECRET, then run `uv run irma-api auth google`
# once to capture a refresh token automatically. Missing creds degrade
# gracefully — the calendar observer no-ops until you grant it.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Recipient address the send_email tool is locked to. The LLM cannot
# override this — exposing it as a tool argument would be a prompt-injection
# vector. Required when the Resend tool is enabled.
IRMA_USER_EMAIL=you@example.com

# Resend — transport for the send_email tool. Get an API key at
# https://resend.com. The default From address (onboarding@resend.dev)
# delivers to the verified account email without requiring a custom domain;
# swap to a domain you own once you've verified it in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Comma-separated absolute paths to local git repos the CodebaseAgent watches.
# Missing / non-git paths are skipped with a warning.
IRMA_REPOS=

# CodebaseAgent is disabled by default — most code lives on SSH servers; the
# local-only variant misses it. Flip to true to re-enable the local git observer.
IRMA_CODEBASE_AGENT_ENABLED=false

# Background re-observation interval (APScheduler).
IRMA_REFRESH_MINUTES=30

# Manual tunable for the companion sprite's vertical offset from the work-area
# bottom edge; consumed by the Tauri side, mirrored here for visibility.
IRMA_DOCK_CLEARANCE=80

# SQLite path (relative paths resolve from the services/api/ cwd).
IRMA_DB_PATH=./irma.db

# Bind address for the uvicorn server.
IRMA_API_HOST=127.0.0.1
IRMA_API_PORT=8765
